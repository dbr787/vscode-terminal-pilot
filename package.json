{
  "name": "terminal-pilot",
  "displayName": "Terminal Pilot",
  "publisher": "local",
  "description": "Cycle all terminals (including splits) and show Claude Code state",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dbr787/vscode-terminal-pilot"
  },
  "categories": ["Other"],
  "engines": { "vscode": "^1.93.0" },
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminalPilot.focusNext",
        "title": "Terminal: Focus Next (All)"
      },
      {
        "command": "terminalPilot.focusPrevious",
        "title": "Terminal: Focus Previous (All)"
      }
    ],
    "keybindings": [
      {
        "command": "terminalPilot.focusNext",
        "key": "ctrl+]"
      },
      {
        "command": "terminalPilot.focusPrevious",
        "key": "ctrl+["
      },
      {
        "command": "workbench.action.terminal.kill",
        "key": "cmd+shift+backspace",
        "when": "terminalFocus"
      },
      {
        "command": "workbench.action.terminal.split",
        "key": "cmd+\\",
        "when": "terminalFocus"
      }
    ],
    "configurationDefaults": {
      "terminal.integrated.commandsToSkipShell": [
        "terminalPilot.focusNext",
        "terminalPilot.focusPrevious"
      ]
    }
  }
}
