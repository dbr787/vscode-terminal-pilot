{
  "name": "terminal-pilot",
  "displayName": "Terminal Pilot",
  "publisher": "local",
  "description": "Cycle all terminals, track Claude/Codex/Amp terminals, and create styled agent terminals",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dbr787/vscode-terminal-pilot"
  },
  "categories": ["Other"],
  "engines": { "vscode": "^1.93.0" },
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": ["ui"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminalPilot.focusNext",
        "title": "Terminal: Focus Next (All)"
      },
      {
        "command": "terminalPilot.focusPrevious",
        "title": "Terminal: Focus Previous (All)"
      },
      {
        "command": "terminalPilot.newClaudeTerminal",
        "title": "Terminal Pilot: New Claude Terminal"
      },
      {
        "command": "terminalPilot.newCodexTerminal",
        "title": "Terminal Pilot: New Codex Terminal"
      },
      {
        "command": "terminalPilot.newAmpTerminal",
        "title": "Terminal Pilot: New Amp Terminal"
      }
    ],
    "terminal": {
      "profiles": [
        {
          "id": "terminalPilot.claude",
          "title": "Terminal Pilot Claude",
          "icon": "claude",
          "color": "terminal.ansiYellow"
        },
        {
          "id": "terminalPilot.codex",
          "title": "Terminal Pilot Codex",
          "icon": "openai",
          "color": "terminal.ansiBlue"
        },
        {
          "id": "terminalPilot.amp",
          "title": "Terminal Pilot Amp",
          "icon": "sparkle",
          "color": "terminal.ansiGreen"
        }
      ]
    },
    "keybindings": [
      {
        "command": "terminalPilot.focusNext",
        "key": "ctrl+]"
      },
      {
        "command": "terminalPilot.focusPrevious",
        "key": "ctrl+["
      },
      {
        "command": "workbench.action.terminal.kill",
        "key": "cmd+shift+backspace",
        "when": "terminalFocus"
      },
      {
        "command": "workbench.action.terminal.split",
        "key": "cmd+\\",
        "when": "terminalFocus"
      },
      {
        "command": "terminalPilot.newClaudeTerminal",
        "key": "cmd+shift+c"
      },
      {
        "command": "terminalPilot.newCodexTerminal",
        "key": "cmd+shift+o"
      },
      {
        "command": "terminalPilot.newAmpTerminal",
        "key": "cmd+shift+a"
      }
    ],
    "configurationDefaults": {}
  }
}
